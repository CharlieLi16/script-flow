# Local development / Vercel Environment Variables

# Team access (hash preferred; plain code also works for dev)
TEAM_ACCESS_CODE=your-team-code
# TEAM_ACCESS_CODE_HASH=sha256-hex-of-code

# Cookie signing secret (required in production)
AUTH_COOKIE_SECRET=change-me-to-random-string

# Shared provider keys (used when team session is active)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Vercel Blob (temporary generation results, optional in dev)
BLOB_READ_WRITE_TOKEN=

# Trigger.dev (background jobs, optional)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# Seed asset CDN base URL (optional)
SEED_ASSET_BASE_URL=

# Legacy local server port
PORT=3847
